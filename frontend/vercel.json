{
  "version": 2,
  "name": "bu-eats",
  "buildCommand": "",
  "routes": [
    { "src": "/",                       "dest": "/student/index.html"       },
    { "src": "/index.html",             "dest": "/student/index.html"       },

    { "src": "/login",                  "dest": "/student/login.html"       },
    { "src": "/login.html",             "dest": "/student/login.html"       },

    { "src": "/register",               "dest": "/student/register.html"    },
    { "src": "/register.html",          "dest": "/student/register.html"    },

    { "src": "/menu",                   "dest": "/student/menu.html"        },
    { "src": "/menu.html",              "dest": "/student/menu.html"        },

    { "src": "/order_status",           "dest": "/student/order_status.html"},
    { "src": "/order_status.html",      "dest": "/student/order_status.html"},

    { "src": "/staff",                  "dest": "/canteen/login.html"       },
    { "src": "/staff/login",            "dest": "/canteen/login.html"       },
    { "src": "/staff/login.html",       "dest": "/canteen/login.html"       },

    { "src": "/staff/register",         "dest": "/canteen/register.html"    },
    { "src": "/staff/register.html",    "dest": "/canteen/register.html"    },

    { "src": "/staff/dashboard",        "dest": "/canteen/dashboard.html"   },
    { "src": "/staff/dashboard.html",   "dest": "/canteen/dashboard.html"   },

    { "src": "/staff/order_detail",     "dest": "/canteen/order_detail.html"},
    { "src": "/staff/order_detail.html","dest": "/canteen/order_detail.html"},

    { "src": "/staff/order_status",     "dest": "/canteen/order_status.html"},
    { "src": "/staff/order_status.html","dest": "/canteen/order_status.html"},

    { "src": "/(.*)",                   "dest": "/$1"                       }
  ]
}