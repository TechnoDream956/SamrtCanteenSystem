# ── B.U Eats — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to git.

# Flask secret key for JWT tokens — change this to a long random string
JWT_SECRET_KEY=change-this-to-a-super-long-random-secret-in-production

# Gmail SMTP — for sending OTP verification emails to @bennett.edu.in students
# Step 1: Use a Gmail account (create a dedicated one e.g. bueatsnoreply@gmail.com)
# Step 2: Enable 2FA on that Gmail
# Step 3: Go to https://myaccount.google.com/apppasswords → create "Mail" app password
# Step 4: Paste that 16-char password below (NOT your real Gmail password)
SMTP_EMAIL=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# PostgreSQL — set automatically by Render when you add a Postgres database
DATABASE_URL=

# CORS — set to your Vercel frontend URL in production
ALLOWED_ORIGINS=*

# (Optional) Set to "production" on Render, leave blank for local dev
FLASK_ENV=development
